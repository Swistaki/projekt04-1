<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head.partial.ejs') %>
    <title><%= title %></title>
</head>
<body>
    <div class="container">
        <div class="movie-detail">
            <h1><%= movie.title %></h1>
            
            <p><strong>Director:</strong> <%= movie.director %></p>
            <% if (movie.year) { %><p><strong>Year:</strong> <%= movie.year %></p><% } %>
            <% if (movie.genre) { %><p><strong>Genre:</strong> <%= movie.genre %></p><% } %>
            <% if (movie.rating) { %>
                <div class="movie-rating">
                    <span>★</span> <%= movie.rating %>/10
                </div>
            <% } %>

            <div class="movie-actions">
                <button onclick="location.href='/movies/<%= movie.id %>/edit'" class="btn btn-edit">Edit</button>
                <form method="post" action="/movies/<%= movie.id %>/delete">
                    <button type="submit" class="btn btn-delete" onclick="return confirm('Delete this movie?')">Delete</button>
                </form>
                <button onclick="location.href='/movies'" class="btn btn-secondary">Back to Movies</button>
            </div>
        </div>
    </div>
    <%- include('./partials/foot.partial.ejs') %>
</body>
</html>
