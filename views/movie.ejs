<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head.partial.ejs') %>
    <title><%= title %></title>
</head>
<body>
    <div class="container">
        <h1><%= movie.title %></h1>
        
        <div style="background: #2a2a2a; padding: 25px; border-radius: 10px; border: 1px solid #3a3a3a; margin: 20px 0;">
            <p><strong>Director:</strong> <%= movie.director %></p>
            <% if (movie.year) { %><p><strong>Year:</strong> <%= movie.year %></p><% } %>
            <% if (movie.genre) { %><p><strong>Genre:</strong> <%= movie.genre %></p><% } %>
            <% if (movie.rating) { %><p><strong>Rating:</strong> <%= movie.rating %>/10</p><% } %>
        </div>

        <div class="movie-actions" style="margin-top: 20px;">
            <a href="/movies/<%= movie.id %>/edit" style="padding: 12px 25px; background: linear-gradient(135deg, #91C3F9 0%, #6BA3D4 100%); color: #000; border-radius: 8px; text-decoration: none; font-weight: 700; display: inline-block; margin-right: 10px;">Edit</a>
            
            <form method="post" action="/movies/<%= movie.id %>/delete" style="display:inline;">
                <button type="submit" onclick="return confirm('Are you sure you want to delete this movie?')" style="padding: 12px 25px; background: #ff6b6b; color: #000; border: none; border-radius: 8px; font-weight: 700; cursor: pointer;">Delete</button>
            </form>
            
            <a href="/movies" style="padding: 12px 25px; background: #3a3a3a; color: #91C3F9; border: 1px solid #91C3F9; border-radius: 8px; text-decoration: none; font-weight: 700; display: inline-block; margin-left: 10px;">Back to List</a>
        </div>
    </div>
    <%- include('./partials/foot.partial.ejs') %>
</body>
</html>