<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head.partial.ejs') %>
    <title><%= title %></title>
</head>
<body>
    <div class="container">
        <h1><%= movie.title %></h1>
        
        <div>
            <p><strong>Director:</strong> <%= movie.director %></p>
            <% if (movie.year) { %><p><strong>Year:</strong> <%= movie.year %></p><% } %>
            <% if (movie.genre) { %><p><strong>Genre:</strong> <%= movie.genre %></p><% } %>
            <% if (movie.rating) { %><p><strong>Rating:</strong> <%= movie.rating %>/10</p><% } %>
        </div>

        <div class="movie-actions">
            <a href="/movies/<%= movie.id %>/edit">Edit</a>
            
            <form method="post" action="/movies/<%= movie.id %>/delete">
                <a onclick="return confirm('Are you sure you want to delete this movie?')">Delete</a>
            </form>

            <a href="/">Back to Home</a>
        </div>
    </div>
    <%- include('./partials/foot.partial.ejs') %>
</body>
</html> 