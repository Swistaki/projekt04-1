<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head.partial.ejs') %>
    <title><%= title %></title>
</head>
<body>
    <div class="container">
        <h1><%= title %></h1>
        
        <% if (errors && errors.length > 0) { %>
            <ul id="errors">
                <% errors.forEach(function(error) { %>
                    <li><%= error %></li>
                <% }) %>
            </ul>
        <% } %>

        <form method="post" action="/movies/<%= movie.id %>/edit">
            <div>
                <label for="title">Title:</label>
                <input type="text" id="title" name="title" value="<%= movie.title %>" required>
            </div>

            <div>
                <label for="director">Director:</label>
                <input type="text" id="director" name="director" value="<%= movie.director %>" required>
            </div>

            <div>
                <label for="year">Year:</label>
                <input type="number" id="year" name="year" value="<%= movie.year || '' %>">
            </div>

            <div>
                <label for="genre">Genre:</label>
                <input type="text" id="genre" name="genre" value="<%= movie.genre || '' %>" placeholder="e.g., Drama, Action">
            </div>

            <div>
                <label for="rating">Rating (0-10):</label>
                <input type="number" id="rating" name="rating" min="0" max="10" step="0.1" value="<%= movie.rating || '' %>" placeholder="0-10">
            </div>

            <button type="submit">Save Changes</button>
            <a href="/movies/<%= movie.id %>" class="btn-cancel">Cancel</a>
        </form>
    </div>
    <%- include('./partials/foot.partial.ejs') %>
</body>
</html>
