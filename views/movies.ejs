<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head.partial.ejs') %>
    <title><%= title %></title>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1><%= title %></h1>
            <a href="/movies/new" class="btn btn-primary">+ Add Movie</a>
        </div>
        
        <% if (movies && movies.length > 0) { %>
            <ul class="movie-list">
                <% movies.forEach(function(movie) { %>
                    <li class="movie-card">
                        <h3><%= movie.title %></h3>
                        <p><strong>Director:</strong> <%= movie.director %></p>
                        <% if (movie.year) { %><p><strong>Year:</strong> <%= movie.year %></p><% } %>
                        <% if (movie.genre) { %><p><strong>Genre:</strong> <%= movie.genre %></p><% } %>
                        <% if (movie.rating) { %>
                            <div class="movie-rating">
                                <span>★</span> <%= movie.rating %>/10
                            </div>
                        <% } %>
                        
                        <div class="movie-actions">
                            <button onclick="location.href='/movies/<%= movie.id %>'" class="btn btn-secondary">View</button>
                            <button onclick="location.href='/movies/<%= movie.id %>/edit'" class="btn btn-edit">Edit</button>
                            <form method="post" action="/movies/<%= movie.id %>/delete">
                                <button type="submit" class="btn btn-delete" onclick="return confirm('Delete this movie?')">Delete</button>
                            </form>
                        </div>
                    </li>
                <% }) %>
            </ul>
        <% } else { %>
            <div class="empty-state">
                <p>No movies in your collection yet.</p>
                <a href="/movies/new" class="btn btn-primary">Add your first movie!</a>
            </div>
        <% } %>
    </div>
    <%- include('./partials/foot.partial.ejs') %>
</body>
</html>
