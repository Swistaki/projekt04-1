<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head.partial.ejs') %>
    <title><%= title %></title>
</head>
<body>
    <div class="container">
        <h1><%= title %></h1>
        
        <a href="/movies/new" class="add-movie-btn">+ Add New Movie</a>

        <% if (movies && movies.length > 0) { %>
            <ul class="movie-list">
                <% movies.forEach(function(movie) { %>
                    <li>
                        <h3><%= movie.title %></h3>
                        <p><strong>Director:</strong> <%= movie.director %></p>
                        <% if (movie.year) { %><p><strong>Year:</strong> <%= movie.year %></p><% } %>
                        <% if (movie.genre) { %><p><strong>Genre:</strong> <%= movie.genre %></p><% } %>
                        <% if (movie.rating) { %><p><strong>Rating:</strong> <%= movie.rating %>/10</p><% } %>
                        
                        <div class="movie-actions">
                            <a href="/movies/<%= movie.id %>" class="btn-edit">View</a>
                            <a href="/movies/<%= movie.id %>/edit" class="btn-edit">Edit</a>
                            <form method="post" action="/movies/<%= movie.id %>/delete" style="display:inline;">
                                <button type="submit" class="btn-delete" onclick="return confirm('Are you sure you want to delete this movie?')">Delete</button>
                            </form>
                        </div>
                    </li>
                <% }) %>
                            <a href="/">Back to Home</a>

            </ul>
        <% } else { %>
            <div class="empty-state">
                <p>No movies yet.</p>
                <a href="/movies/new" class="add-movie-btn">Add your first movie!</a>
            </div>
        <% } %>
    </div>
    <%- include('./partials/foot.partial.ejs') %>
</body>
</html>